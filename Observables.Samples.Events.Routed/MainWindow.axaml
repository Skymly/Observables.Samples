<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Observables.Samples.Events.Routed.MainWindow"
        Title="Observables.Events — AttachedRoutedEvent"
        Width="420"
        Height="200">
  <StackPanel Margin="16" Spacing="12">
    <TextBlock x:Name="StatusText" Text="Click the button to raise an attached routed stream." />
    <Panel x:Name="HostPanel">
      <Button x:Name="DemoButton" Content="Click me" HorizontalAlignment="Left" />
    </Panel>
  </StackPanel>
</Window>
